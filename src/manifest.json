{
  "manifest_version": 3,
  "name": "Go Codes",
  "version": "1.1.0",
  "description": "Omnibox shortcodes for URLs, synced via Chrome.",
  "permissions": ["storage"],
  "omnibox": { "keyword": "go" },
  "background": { "service_worker": "background.js" },
  "options_page": "manage.html",
  "action": {
    "default_title": "Go Codes",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "key": ""
}
